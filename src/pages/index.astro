---
import RichText from '../components/RichText.astro';
import content from '../data/content.json';

const { association, sections, actualites, images } = content;
const { contact } = association;

---
<!doctype html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={association.slogan} />
  <title>{association.nom} — {association.slogan}</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body class="bg-slate-50 text-slate-800 font-sans">

  <!-- En-tête transparent fixe, devient vert au défilement -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <img src="/images/logo-apcm.png" alt={`Logo ${association.nom}`} class="h-16 w-auto drop-shadow" />
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-white drop-shadow">{association.nom}</h1>
          <p class="text-white/80 text-sm mt-0.5 drop-shadow">{association.slogan}</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        {contact.facebook && (
          <a href={contact.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook APCM">
            <img src="/images/facebook.png" alt="Facebook" class="h-10 w-auto object-contain drop-shadow" />
          </a>
        )}
        {contact.whatsapp && (
          <a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="Groupe WhatsApp APCM">
            <img src="/images/whatsapp-2288548_640.png" alt="WhatsApp" class="h-10 w-auto object-contain drop-shadow" />
          </a>
        )}
        {contact.helloasso && (
          <a href={contact.helloasso} target="_blank" rel="noopener noreferrer" aria-label="Adhérer via HelloAsso">
            <img src="/images/helloasso.png" alt="HelloAsso" class="h-10 w-auto object-contain drop-shadow" />
          </a>
        )}
      </div>
    </div>
  </header>

  <!-- Image de fond plein écran (passe sous l'en-tête transparent) -->
  <div class="relative h-screen w-full overflow-hidden">
    <picture>
      <source srcset="/images/train-hiver.webp" type="image/webp" />
      <img
        src={images.couverture || "/images/train-hiver.jpg"}
        alt="Train de la ligne Colmar-Metzeral en hiver"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
    </picture>
    <div class="absolute inset-0 bg-black/45 flex items-center justify-center">
      <div class="text-center text-white px-6">
        <h2 class="text-4xl md:text-5xl font-bold drop-shadow-lg">{association.nom}</h2>
        <p class="text-xl mt-4 text-white/90 drop-shadow max-w-xl mx-auto">{association.slogan}</p>
        <a href="#presentation" class="mt-8 inline-block bg-green-700 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-full transition-colors shadow-lg">
          Découvrir
        </a>
      </div>
    </div>
  </div>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-14">

    <!-- Présentation -->
    <section id="presentation" class="scroll-mt-24">
      <RichText content={association.description} class="text-lg leading-relaxed text-slate-700" />
    </section>

    <!-- Sections dynamiques -->
    {sections.map((section) => (
      <section class="border-t border-slate-200 pt-10">
        <h2 class="text-xl font-semibold text-green-800 mb-4">{section.titre}</h2>
        <RichText content={section.contenu} />
      </section>
    ))}

    <!-- Actualités -->
    {actualites.length > 0 && (
      <section id="actualites" class="border-t border-slate-200 pt-10 scroll-mt-24">
        <h2 class="text-xl font-semibold text-green-800 mb-6">Actualités</h2>
        <div class="space-y-8">
          {actualites.map((actu) => (
            <article class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
              {actu.image && (
                <img src={actu.image} alt={actu.titre} class="w-full h-48 object-cover" />
              )}
              <div class="p-6">
                <p class="text-xs text-slate-400 mb-1">
                  {new Date(actu.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
                <h3 class="text-lg font-semibold text-slate-900 mb-2">{actu.titre}</h3>
                <p class="text-slate-600 mb-4">{actu.resume}</p>
                <RichText content={actu.contenu} class="text-sm" />
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Formulaire de contact -->
    <section id="contact" class="border-t border-slate-200 pt-10 scroll-mt-24">
      <h2 class="text-xl font-semibold text-green-800 mb-6">Nous contacter</h2>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />
        <!-- Champ honeypot anti-spam (invisible pour les humains) -->
        <p class="hidden">
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 mb-1">
            Nom <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="text" id="name" name="name" required autocomplete="name"
            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
            Adresse e-mail <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="email" id="email" name="email" required autocomplete="email"
            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 mb-1">
            Message <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <textarea
            id="message" name="message" rows="6" required
            class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="bg-green-700 hover:bg-green-600 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors"
        >
          Envoyer le message
        </button>
      </form>
    </section>

  </main>

  <footer class="bg-green-900 text-green-200 text-center text-sm py-6 mt-14">
    <p>© {new Date().getFullYear()} {association.nom} — {association.slogan}</p>
  </footer>

  <script>
    const header = document.getElementById('site-header');
    function updateHeader() {
      if (window.scrollY > 60) {
        header?.classList.add('bg-green-900', 'shadow-lg');
      } else {
        header?.classList.remove('bg-green-900', 'shadow-lg');
      }
    }
    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  </script>

</body>
</html>
