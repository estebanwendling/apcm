---
import RichText from '../components/RichText.astro';
import content from '../data/content.json';

const { association, sections, actualites } = content;
const { contact } = association;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={association.slogan} />
  <title>{association.nom} — {association.slogan}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-slate-50 text-slate-800 font-sans">

  <!-- En-tête : logo à gauche, icônes sociales à droite -->
  <header class="bg-green-800 text-white shadow-lg">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <img src="/images/logo-apcm.png" alt={`Logo ${association.nom}`} class="h-16 w-auto" />
        <div>
          <h1 class="text-2xl font-bold tracking-tight">{association.nom}</h1>
          <p class="text-green-200 text-sm mt-0.5">{association.slogan}</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        {contact.facebook && (
          <a href={contact.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook APCM">
            <img src="/images/facebook.png" alt="Facebook" class="h-10 w-auto object-contain" />
          </a>
        )}
        {contact.whatsapp && (
          <a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="Groupe WhatsApp APCM">
            <img src="/images/whatsapp-2288548_640.png" alt="WhatsApp" class="h-10 w-auto object-contain" />
          </a>
        )}
        {contact.helloasso && (
          <a href={contact.helloasso} target="_blank" rel="noopener noreferrer" aria-label="Adhérer via HelloAsso">
            <img src="/images/helloassologo.jpg" alt="HelloAsso" class="h-10 w-auto object-contain" />
          </a>
        )}
      </div>
    </div>
  </header>

  <!-- Image de fond plein écran -->
  <div class="relative h-screen w-full overflow-hidden">
    <img
      src="/images/train-hiver.jpg"
      alt="Train de la ligne Colmar-Metzeral en hiver"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/45 flex items-center justify-center">
      <div class="text-center text-white px-6">
        <h2 class="text-4xl md:text-5xl font-bold drop-shadow-lg">{association.nom}</h2>
        <p class="text-xl mt-4 text-white/90 drop-shadow max-w-xl mx-auto">{association.slogan}</p>
        <a href="#presentation" class="mt-8 inline-block bg-green-700 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-full transition-colors shadow-lg">
          Découvrir
        </a>
      </div>
    </div>
  </div>

  <main class="max-w-4xl mx-auto px-6 py-10 space-y-14">

    <!-- Présentation -->
    <section id="presentation">
      <RichText content={association.description} class="text-lg leading-relaxed text-slate-700" />
    </section>

    <!-- Sections dynamiques -->
    {sections.map((section) => (
      <section class="border-t border-slate-200 pt-10">
        <h2 class="text-xl font-semibold text-green-800 mb-4">{section.titre}</h2>
        <RichText content={section.contenu} />
      </section>
    ))}

    <!-- Actualités -->
    {actualites.length > 0 && (
      <section id="actualites" class="border-t border-slate-200 pt-10">
        <h2 class="text-xl font-semibold text-green-800 mb-6">Actualités</h2>
        <div class="space-y-8">
          {actualites.map((actu) => (
            <article class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
              {actu.image && (
                <img src={actu.image} alt={actu.titre} class="w-full h-48 object-cover" />
              )}
              <div class="p-6">
                <p class="text-xs text-slate-400 mb-1">
                  {new Date(actu.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
                <h3 class="text-lg font-semibold text-slate-900 mb-2">{actu.titre}</h3>
                <p class="text-slate-600 mb-4">{actu.resume}</p>
                <RichText content={actu.contenu} class="text-sm" />
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Contact -->
    <section id="contact" class="border-t border-slate-200 pt-10">
      <h2 class="text-xl font-semibold text-green-800 mb-6">Nous contacter</h2>
      <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 grid sm:grid-cols-2 gap-4">

        {contact.mail && (
          <a href={`mailto:${contact.mail}`} class="flex items-center gap-3 text-slate-700 hover:text-green-700 transition-colors">
            <span class="text-2xl">✉️</span>
            <span>{contact.mail}</span>
          </a>
        )}

        {contact.telephone && (
          <a href={`tel:${contact.telephone}`} class="flex items-center gap-3 text-slate-700 hover:text-green-700 transition-colors">
            <span class="text-2xl">📞</span>
            <span>{contact.telephone}</span>
          </a>
        )}

        {contact.facebook && (
          <a href={contact.facebook} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-slate-700 hover:text-green-700 transition-colors">
            <img src="/images/facebook.png" alt="" class="h-6 w-auto" />
            <span>Facebook</span>
          </a>
        )}

        {contact.whatsapp && (
          <a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-slate-700 hover:text-green-700 transition-colors">
            <img src="/images/whatsapp-2288548_640.png" alt="" class="h-6 w-auto" />
            <span>Groupe WhatsApp</span>
          </a>
        )}

        {contact.helloasso && (
          <a href={contact.helloasso} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-slate-700 hover:text-green-700 transition-colors">
            <img src="/images/helloassologo.jpg" alt="" class="h-6 w-auto" />
            <span>Adhérer / Faire un don (HelloAsso)</span>
          </a>
        )}

        {contact.adresse && (
          <div class="flex items-center gap-3 text-slate-700">
            <span class="text-2xl">📍</span>
            <span>{contact.adresse}</span>
          </div>
        )}

      </div>
    </section>

  </main>

  <footer class="bg-green-900 text-green-200 text-center text-sm py-6 mt-14">
    <p>© {new Date().getFullYear()} {association.nom} — {association.slogan}</p>
  </footer>

</body>
</html>
